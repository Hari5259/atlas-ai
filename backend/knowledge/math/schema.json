{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "MathematicsKnowledgeEntry",
  "type": "object",
  "required": ["id", "topic", "title", "content", "keywords", "difficulty"],
  "properties": {
    "id": { "type": "string", "pattern": "^math-" },
    "topic": { "type": "string" },
    "title": { "type": "string" },
    "content": { "type": "string" },
    "formula": { "type": "string" },
    "example": { "type": "string" },
    "keywords": { "type": "array", "items": { "type": "string" } },
    "difficulty": { "enum": ["beginner", "intermediate", "advanced"] }
  }
}
